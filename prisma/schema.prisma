// Prisma schema - Colegios Arquidiocesanos
// Base de datos: SQLite (archivo local) para desarrollo

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String?  @unique
  email       String   @unique
  password    String
  name        String
  displayName String   @default("")
  role        String   @default("editor")
  permisos    String   @default("{}")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Colegio {
  id              String   @id @default(cuid())
  slug            String   @unique
  nombre          String
  descripcion     String
  direccion       String
  zona            String
  telefono        String
  email           String
  facebook        String?
  calendario      String   // "A" | "B"
  jornadas        String   // JSON array
  niveles         String   // JSON array
  estudiantes     Int      @default(0)
  docentes        Int      @default(0)
  fundacion       Int      @default(2000)
  egresados       Int?
  caracteristicas String   // JSON array
  logo            String?
  publicado       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Noticia {
  id         String   @id @default(cuid())
  slug       String   @unique
  titulo     String
  resumen    String
  contenido  String
  categoria  String
  fecha      DateTime
  autor      String
  imagen     String
  destacada  Boolean  @default(false)
  publicada  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ColegioDetalle {
  id           String   @id @default(cuid())
  colegioSlug  String   @unique

  ofertaTitulo String   @default("Nuestra Oferta Académica")
  ofertaCopy   String   @default("")
  ofertaItems  String   @default("[]") // JSON: [{icono,titulo,descripcion?}]

  equipo           String   @default("[]") // JSON: [{nombre,cargo,foto?}]
  testimonios      String   @default("[]") // JSON: [{texto,nombre,relacion,foto?,video?}]
  testimoniosVideo String   @default("[]") // JSON: [{titulo?,autor?,url,tipo:"url"|"local"}]
  galeria          String   @default("[]") // JSON: [{url,alt?}]
  costos       String   @default("[]") // JSON: [{grado,matricula,pension}] — Cal B only

  heroFondo        String   @default("")
  heroOverlay      Int      @default(80)
  heroOverlayColor String   @default("#000000")
  heroContenedor   String   @default("")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ComentarioInforme {
  id         String   @id @default(cuid())
  fundacion  String   // "FESIH" | "FAUU"
  anio       Int
  nombre     String
  comentario String
  createdAt  DateTime @default(now())
}

model Documento {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  categoria   String   @default("General")
  nombreArchivo String
  rutaArchivo   String  // Ruta relativa en /uploads
  tamano      Int      // bytes
  contenido   String   // Texto extraído del PDF para RAG
  paginas     Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SaraConversation {
  id        String   @id @default(cuid())
  senderId  String   @unique
  name      String?
  email     String?
  phone     String?
  messages  SaraMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SaraMessage {
  id             String            @id @default(cuid())
  conversation   SaraConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  role           String            // "user" | "assistant"
  content        String
  source         String?           // "local" | "crm"
  createdAt      DateTime          @default(now())
}

model Modal {
  id            String   @id @default(cuid())
  title         String
  content       String   @default("")
  imageUrl      String?
  badge         String?
  ctaText       String?
  ctaUrl        String?
  pageUrl       String   @default("*") // "*" = all pages, or specific path like "/colegios"
  startDate     DateTime?
  endDate       DateTime?
  trigger       String   @default("immediate") // immediate, delay, scroll, exit_intent
  delaySeconds  Int      @default(0)
  scrollPercent Int      @default(0)
  isActive      Boolean  @default(true)
  showOnce      Boolean  @default(true)
  position      String   @default("center") // center, bottom_right
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model HomeConfig {
  id            String   @id @default(cuid())
  heroSlides    String   @default("[]") // JSON: [{imageUrl,videoUrl?,badge,title,copy,ctaText,ctaUrl,alignment}]
  stats         String   @default("[]") // JSON: [{icon,label,value,suffix,isText,text}]
  whyChoose     String   @default("[]") // JSON: [{icon,title,description,color,iconClass}]
  alliances     String   @default("[]") // JSON: [{logo,nombre,beneficio}]
  testimonials  String   @default("[]") // JSON: [{nombre,colegio,texto,iniciales}]
  faq           String   @default("[]") // JSON: [{icon,pregunta,respuesta,link?}]
  ctaTitle      String   @default("¿Listo para dar el primer paso?")
  ctaCopy       String   @default("Únete a nuestra comunidad de más de 29,000 estudiantes. Tu hijo merece la mejor educación.")
  ctaPrimary    String   @default("/admisiones")
  ctaPrimaryLabel String @default("Ver proceso de admisión")
  ctaSecondary    String   @default("https://runachay.com")
  ctaSecondaryLabel String @default("Inscribir en Runachay")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
