# Copia este archivo a .env y rellena los valores

# ── Base de datos ───────────────────────────────────────────────────────────
# Prisma / PostgreSQL (Supabase). En serverless (Vercel) usa el TRANSACTION
# POOLER (puerto 6543) con pgbouncer. El pooler de session (5432) agota
# conexiones en funciones serverless.
# App (runtime serverless): transaction pooler 6543 + pgbouncer
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Migraciones (prisma migrate / db push): conexión directa o session pooler 5432
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres"

# ── Autenticación ───────────────────────────────────────────────────────────
# JWT secret - genera uno aleatorio largo (>= 32 caracteres)
JWT_SECRET="cambia-este-secreto-por-uno-largo-y-aleatorio-minimo-32-chars"

# Admin inicial (usado en el seed: npm run db:seed)
ADMIN_EMAIL="admin@arquidiocesanos.edu.co"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="Administrador"

# ── IA / LLMs ───────────────────────────────────────────────────────────────
# DeepSeek API — chat Sara + gestor documentos (/api/chat, /api/sara)
DEEPSEEK_API_KEY="tu-api-key-de-deepseek"

# Google Gemini API — módulo alternativo (/lib/gemini.ts)
GEMINI_API_KEY="tu-api-key-de-google-gemini"
GEMINI_MODEL="gemini-2.0-flash"

# ── Correo SMTP ─────────────────────────────────────────────────────────────
# Usado por: /api/contacto, /api/acoso, /api/comite-convivencia
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tucorreo@gmail.com"
SMTP_PASS="tu-app-password-de-gmail"

# Destino para formulario "Trabaja con Nosotros" (/api/contacto)
CONTACT_EMAIL="seleccion@arquidiocesanos.edu.co"

# ── Sincronización con CRM ─────────────────────────────────────────────────
# API key para sincronizar colegios desde el CRM (/api/sync/colegios)
SYNC_API_KEY="50P0R73B."

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL y Service Role Key (desde Project Settings > API en Supabase)
# WARNING: La Service Role Key tiene acceso total. Nunca expongas en el cliente.
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"

# ── CRM Webchat ─────────────────────────────────────────────────────────────
# URL del webhook del CRM para conectar el chatbot Sara (/api/webhooks/webchat)
CRM_WEBCHAT_URL="https://crm-colarqui.vercel.app/api/webhooks/webchat"
